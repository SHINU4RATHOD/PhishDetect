# ─────────────────────────────────────────────────────────────────────────────
# PhishGuard — Android .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# Android Studio / IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Local configuration (SDK paths, etc.)
local.properties

# Kotlin
.kotlin/

# OS-generated
.DS_Store
Thumbs.db
desktop.ini

# APK / AAB output
*.apk
*.aab
*.ap_

# Signing keys
*.jks
*.keystore

# Log files
*.log

# Captures (Android Studio profiling)
captures/

# External native build
.cxx/
.externalNativeBuild/
